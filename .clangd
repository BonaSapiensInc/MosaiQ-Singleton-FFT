CompileFlags:
  CompilationDatabase: build

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: Strict

---
If:
  PathMatch: .*\.(hpp|h)$
CompileFlags:
  Add:
    - -std=c++20
    - -x
    - c++-header
    - -Isrc

---
If:
  PathMatch: tests/.*
CompileFlags:
  Add:
    - -std=c++20
    - -Isrc
    - -Ibuild/_deps/catch2-src/src/catch2/..
    - -Ibuild/_deps/catch2-build/generated-includes
